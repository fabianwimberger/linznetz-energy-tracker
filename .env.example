# Copy this file to `.env` and adjust as needed. Docker Compose loads
# `.env` automatically; `.env` is gitignored so secrets stay local.

# --- Web server -------------------------------------------------------------

# Host port the UI is exposed on
PORT=8000

# Container timezone (used by date math and log timestamps)
TZ=Europe/Vienna

# Comma-separated allowed origins for the API. "*" is fine for local use;
# set to your real hostname when exposing the app.
CORS_ORIGINS=*

# --- LinzNetz portal auto-fetch (optional) ----------------------------------
#
# Setting both LINZNETZ_USERNAME and LINZNETZ_PASSWORD enables the
# "Fetch latest from LinzNetz" button in the UI (POST /api/fetch).
# Without these, the endpoint returns 503 and the rest of the app works
# unchanged — you can still upload CSVs manually.

# LINZNETZ_USERNAME=you@example.com
# LINZNETZ_PASSWORD=your-portal-password

# How many past days the fetch button checks for missing data (default 7).
# LINZNETZ_LOOKBACK_DAYS=7
